# Ports locaux
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
UMAMI_PORT=3003
GLITCHTIP_PORT=8000

# Remplacer les valeurs ci-dessous hors environnement local.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

UMAMI_DB_PASSWORD=change-me
UMAMI_APP_SECRET=change-me-with-a-long-random-value
UMAMI_SCRIPT_URL=http://localhost:3003/script.js
# À renseigner après avoir créé le site dans l'interface Umami.
UMAMI_WEBSITE_ID=

GLITCHTIP_DB_PASSWORD=change-me
GLITCHTIP_SECRET_KEY=change-me-with-a-long-random-value
GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_DEFAULT_FROM_EMAIL=admin@comutitres.local
# DSN du projet GlitchTip utilisé par les SDK frontend et backend.
GLITCHTIP_DSN=
